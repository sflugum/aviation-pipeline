# Docker MySQL Initialization
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=your_mysql_database
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password

# Docker PostgreSQL Initialization
POSTGRES_DATABASE=your_postgres_database
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# Java Appplication Config: Bronze Layer (MySQL)
BRONZE_DB_HOST=mysql-bronze
BRONZE_DB_USER=your_bronze_database_user
BRONZE_DB_PASSWORD=your_bronze_db_password

# Java Application Config: Gold Layer (PostgreSQL)
GOLD_DB_HOST=postgres-gold
GOLD_DB_USER=your_gold_database_user
GOLD_DB_PASSWORD=your_gold_db_password

